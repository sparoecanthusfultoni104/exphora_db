{
  "productName": "ExphoraDB",
  "version": "0.7.1",
  "identifier": "com.exphoradb.app",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "ui",
      "waitFor": "localhost:5173"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "ui"
    }
  },
  "app": {
    "security": {
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "title": "ExphoraDB",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/extension/exh.ico"
    ]
  }
}