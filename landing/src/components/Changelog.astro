---
// src/components/Changelog.astro
const updates = [
  {
    version: "v0.7.2",
    date: "March 11, 2026",
    title: "Views, Persistence & Notes Panel",
    description: "The biggest productivity update yet. Introducing Exphora Views, Smart Save, floating Markdown notes, and column annotations.",
    changes: [
      { type: "Added", text: "View system (.exh files): seamlessly save and restore complete tab states including active filters, column configurations, sorting, calculated columns, pinned columns, and chart states directly to disk." },
      { type: "Added", text: "Smart Save: after saving a view once, the Save button writes directly to the same file without reopening the dialog. A secondary (...) button lets you save to a new location anytime." },
      { type: "Added", text: "Automatic filename suggestion: when saving a view for the first time, the OS dialog pre-fills the name based on the active dataset (e.g. ventas_2025.exh)." },
      { type: "Added", text: "Floating Markdown notes panel per view: a freely draggable, resizable window with Code, Preview, and Split modes. Notes persist inside the .exh file." },
      { type: "Added", text: "Column annotations: add short notes to any column directly from the header context menu. A discrete dot indicator and tooltip appear on annotated columns. Persisted inside the .exh file." },
      { type: "Added", text: "Recent Views section in the Sidebar: tracks the last opened views across sessions for quick access." },
      { type: "Added", text: "RelinkModal: when a view's underlying dataset has been moved or renamed, ExphoraDB detects it and lets you locate the file manually to restore the session." },
      { type: "Added", text: "Native .exh file association on Windows: open any saved view directly from Explorer." },
      { type: "Fixed", text: "Landing page blank screen caused by missing <!DOCTYPE html> declaration (Tailwind v4 Quirks Mode regression)." },
      { type: "Fixed", text: "Resolved deep search highlight overlaps and column-specific field:value filter logic regressions." }
    ]
  }
];
---

<section id="changelog" class="py-24 px-6 max-w-4xl mx-auto border-t border-border/40 mt-12">
  <div class="mb-16">
    <h2 class="text-[2rem] font-bold text-text-primary mb-2 tracking-tight">What's New</h2>
    <p class="text-text-secondary text-[15px]">Keep up with the latest features, fixes, and architectural improvements.</p>
  </div>

  <div class="changelog-list space-y-12">
    {updates.map((update) => (
      <div class="changelog-item opacity-0 translate-y-[20px] relative pl-8 md:pl-0">
        
        {/* Desktop Layout timeline line */}
        <div class="hidden md:block absolute left-[120px] top-2 bottom-[-48px] w-px bg-border/50 last:bottom-0 z-0"></div>
        <div class="hidden md:block absolute left-[116px] top-[14px] w-[9px] h-[9px] rounded-full bg-brand border-[2px] border-bg z-10"></div>

        <div class="flex flex-col md:flex-row gap-4 md:gap-12 relative z-10">
          
          <div class="md:w-[100px] shrink-0 pt-1">
            <span class="inline-block px-2 py-0.5 rounded textxs font-semibold bg-surface-elevated text-brand border border-border/60 mb-1">
              {update.version}
            </span>
            <div class="text-[13px] text-text-muted mt-1">{update.date}</div>
          </div>

          <div class="flex-1 bg-surface border border-border/60 rounded-xl p-6 hover:border-border transition-colors">
            <h3 class="text-lg font-bold text-text-primary tracking-tight mb-2">{update.title}</h3>
            <p class="text-text-secondary text-[14px] leading-relaxed mb-6">{update.description}</p>
            
            <ul class="space-y-3">
              {update.changes.map(change => (
                <li class="flex items-start gap-3 text-[14px] text-text-secondary">
                  <span class={`shrink-0 mt-0.5 inline-flex items-center justify-center px-1.5 py-[2px] rounded font-medium text-[10px] uppercase tracking-wider
                    ${change.type === 'Added' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 
                      change.type === 'Fixed' ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20' : 
                      'bg-blue-500/10 text-blue-400 border border-blue-500/20'}
                  `}>
                    {change.type}
                  </span>
                  <span class="leading-relaxed">{change.text}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    ))}
  </div>
  <div class="mt-12 text-center mt-8">
      <a href="https://github.com/Nuulz/Exphora_db/releases" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[14px] font-medium text-brand hover:text-brand-hover transition-colors">
        View complete commit history
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
  </div>
</section>

<script>
  import { animate, inView } from 'motion';

  const items = document.querySelectorAll('.changelog-item');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  
  if (!prefersReducedMotion && items.length > 0) {
    inView('.changelog-list', () => {
      animate(Array.from(items), 
        { opacity: [0, 1], y: [20, 0] }, 
        { duration: 0.5, delay: (index) => index * 0.1, ease: 'easeOut' }
      );
    }, { margin: "-10% 0px", once: true });
  } else {
    items.forEach(el => {
      if (el instanceof HTMLElement) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      }
    });
  }
</script>
