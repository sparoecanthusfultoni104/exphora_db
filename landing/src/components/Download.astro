---
// src/components/Download.astro
---
<section class="py-24 px-6 relative max-w-4xl mx-auto">
  <div class="download-container opacity-0 translate-y-[20px] bg-surface-elevated border border-border rounded-xl p-12 text-center relative overflow-hidden shadow-sm">
    <div class="absolute inset-0 bg-brand/5 blur-[50px] rounded-xl pointer-events-none"></div>
    
    <div class="relative z-10">
      <h2 class="text-[2rem] font-bold text-text-primary mb-4 tracking-tight">Ready to explore your data?</h2>
      <p class="text-text-secondary text-lg mb-8">Free. Open source. No account needed.</p>
      
      <a href="https://github.com/Nuulz/Exphora_db/releases" class="inline-flex items-center justify-center h-[44px] px-8 bg-brand text-white font-medium rounded-md hover:bg-brand-hover transition-colors mb-4 border border-transparent">
        Download ExphoraDB v0.7.2
      </a>
      
      <p class="text-[13px] text-text-muted">
        Windows 10/11 x64 &middot; ~8MB installer
      </p>
    </div>
  </div>
</section>

<script>
  import { animate, inView } from 'motion';

  const container = document.querySelector('.download-container');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (container) {
    if (!prefersReducedMotion) {
      inView(container, () => {
        animate(container, 
          { opacity: [0, 1], y: [20, 0] }, 
          { duration: 0.5, ease: 'easeOut' }
        );
      }, { margin: "-10% 0px", once: true });
    } else {
      const el = container as HTMLElement;
      el.style.opacity = '1';
      el.style.transform = 'none';
    }
  }
</script>
